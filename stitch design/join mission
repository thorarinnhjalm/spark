<body class="font-body-md text-on-background selection:bg-primary-fixed flex flex-col items-center justify-center p-gutter">
<!-- Sub-page context: Suppress Navigation Shells as per instruction for Transactional/Onboarding pages -->
<main class="w-full max-w-lg flex flex-col items-center">
<!-- Brand Logo for Onboarding -->
<div class="mb-lg text-center">
<span class="font-h1 text-primary-container tracking-tighter block mb-2">Spark AI</span>
<p class="font-body-lg text-on-surface-variant px-md">Búðu til þinn eigin heim með gervigreind!</p>
</div>
<!-- Main Onboarding Card -->
<div class="glass-panel w-full rounded-[32px] p-md md:p-lg shadow-[0_20px_50px_rgba(109,59,215,0.15)] flex flex-col gap-8 relative overflow-hidden">
<!-- Decorative Glow Background -->
<div class="absolute -top-24 -right-24 w-48 h-48 bg-secondary-container opacity-20 blur-3xl rounded-full"></div>
<div class="absolute -bottom-24 -left-24 w-48 h-48 bg-primary-container opacity-20 blur-3xl rounded-full"></div>
<div class="relative z-10 space-y-6">
<!-- Header -->
<div class="text-center space-y-2">
<h2 class="font-h2 text-on-surface">Skráðu þig inn</h2>
<p class="font-body-md text-on-surface-variant">Notaðu kódann sem foreldri þitt fékk.</p>
</div>
<!-- Form Fields -->
<div class="space-y-gutter">
<!-- Invite Code -->
<div class="group">
<label class="font-label-caps text-primary-container ml-2 mb-2 block">Boðskóði</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-primary-container" data-icon="key">key</span>
<input class="w-full pl-12 pr-4 py-5 rounded-2xl bg-white border-2 border-surface-variant focus:border-primary-container focus:ring-0 transition-all text-h3 text-on-surface placeholder:text-surface-variant font-h3 tracking-widest uppercase" placeholder="DÆMI: SPARK-123" type="text"/>
</div>
</div>
<!-- Nickname -->
<div class="group">
<label class="font-label-caps text-primary-container ml-2 mb-2 block">Gælunafn</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-primary-container" data-icon="face">face</span>
<input class="w-full pl-12 pr-4 py-5 rounded-2xl bg-white border-2 border-surface-variant focus:border-primary-container focus:ring-0 transition-all text-body-lg text-on-surface placeholder:text-surface-variant font-semibold" placeholder="Hvað heitir þú í leiknum?" type="text"/>
</div>
</div>
<!-- Secret Password -->
<div class="group">
<label class="font-label-caps text-primary-container ml-2 mb-2 block">Leyniorð</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-primary-container" data-icon="lock" data-weight="fill" style="font-variation-settings: 'FILL' 1;">lock</span>
<input class="w-full pl-12 pr-4 py-5 rounded-2xl bg-white border-2 border-surface-variant focus:border-primary-container focus:ring-0 transition-all text-body-lg text-on-surface placeholder:text-surface-variant" placeholder="••••••••" type="password"/>
</div>
</div>
</div>
<!-- Primary Action -->
<button class="w-full py-6 rounded-[24px] bg-gradient-to-r from-primary-container to-secondary-container text-white font-h2 shadow-lg shadow-primary-fixed hover:scale-[1.02] active:scale-[0.98] transition-all flex items-center justify-center gap-4 group">
<span>Hefja leik!</span>
<span class="material-symbols-outlined group-hover:translate-x-2 transition-transform" data-icon="rocket_launch" data-weight="fill" style="font-variation-settings: 'FILL' 1;">rocket_launch</span>
</button>
</div>
</div>
<!-- Secondary Navigation for the screen -->
<div class="mt-lg flex flex-col items-center gap-4">
<p class="font-body-md text-on-surface-variant">Vantar þig hjálp?</p>
<div class="flex gap-gutter">
<a class="font-label-caps text-primary-container hover:underline py-2 px-4 glass-panel rounded-full" href="#">Hafðu samband</a>
<a class="font-label-caps text-on-surface-variant hover:underline py-2 px-4 glass-panel rounded-full" href="#">Gleymt leyniorð</a>
</div>
</div>
<!-- Visual Elements / Mascot Placeholder -->
<div class="mt-xl grid grid-cols-2 gap-gutter w-full">
<div class="glass-panel rounded-[24px] p-gutter flex flex-col items-center text-center gap-2">
<div class="w-16 h-16 rounded-full bg-primary-fixed flex items-center justify-center mb-2">
<span class="material-symbols-outlined text-primary-container text-[32px]" data-icon="auto_awesome" data-weight="fill" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
</div>
<h3 class="font-h3 text-on-surface text-[18px]">Galdrar</h3>
<p class="font-body-md text-on-surface-variant text-[14px]">Lærðu að búa til hluti með skipunum.</p>
</div>
<div class="glass-panel rounded-[24px] p-gutter flex flex-col items-center text-center gap-2">
<div class="w-16 h-16 rounded-full bg-secondary-fixed flex items-center justify-center mb-2">
<span class="material-symbols-outlined text-secondary-container text-[32px]" data-icon="group" data-weight="fill" style="font-variation-settings: 'FILL' 1;">group</span>
</div>
<h3 class="font-h3 text-on-surface text-[18px]">Vinir</h3>
<p class="font-body-md text-on-surface-variant text-[14px]">Skoðaðu heimana sem aðrir hafa smíðað.</p>
</div>
</div>
</main>
